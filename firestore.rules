rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /tasks/{taskId} {
      allow read: if true;
      allow create: if validTask(request.resource.data);
      allow update: if validTask(request.resource.data);
      allow delete: if true;
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if docId == 'default' && validSettings(request.resource.data);
    }

    // Reject all other collections
    match /{document=**} {
      allow read, write: if false;
    }

    function validTask(data) {
      return data.title is string
        && data.title.size() > 0
        && data.title.size() <= 500
        && data.priority in ['Top', 'High', 'Medium', 'Low']
        && data.status in ['Pending', 'Completed', 'Done', 'Skipped', 'Incomplete', 'Snoozed']
        && (!('tags' in data) || data.tags is list)
        && (!('subtasks' in data) || data.subtasks is list);
    }

    function validSettings(data) {
      return (!('whatsappNumber' in data) || data.whatsappNumber is string)
        && (!('telegramChatId' in data) || data.telegramChatId is string)
        && (!('timezone' in data) || data.timezone is string);
    }
  }
}
